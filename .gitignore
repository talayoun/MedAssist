# Keep: docs/superpowers/ (design specs and plans are project artifacts)
# Ignore: local settings and session state only
.claude/settings.local.json
.claude/todos/
.claude/scheduled_tasks.lock

# Playwright test artifacts
.playwright-mcp/

# Ad-hoc smoke test screenshots
*-checklist-*.png
*-smoke-*.png
